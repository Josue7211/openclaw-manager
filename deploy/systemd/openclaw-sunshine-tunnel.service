[Unit]
Description=OpenClaw VM Sunshine TCP tunnel
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
ExecStart=/usr/bin/ssh -o BatchMode=yes -o ConnectTimeout=10 -o TCPKeepAlive=yes -o ServerAliveInterval=15 -o ServerAliveCountMax=2 -o ExitOnForwardFailure=yes -N -L 127.0.0.1:47984:127.0.0.1:47984 -L 127.0.0.1:47989:127.0.0.1:47989 -L 127.0.0.1:47990:127.0.0.1:47990 -L 127.0.0.1:48010:127.0.0.1:48010 openclaw-vm
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
