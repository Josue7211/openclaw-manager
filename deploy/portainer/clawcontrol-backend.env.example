STACK_BUILD_CONTEXT=/opt/clawcontrol-backend
SECRET_BROKER_BUILD_CONTEXT=/opt/clawcontrol-backend/secret-broker
FRONTEND_BIND=127.0.0.1:8088
FRONTEND_PUBLIC_API_BASE=https://coaching.aparcedo.org
FRONTEND_PUBLIC_SITE_URL=https://coaching.aparcedo.org
FRONTEND_PUBLIC_ASSET_BASE=/
BACKEND_BIND=127.0.0.1:3000
BACKEND_BIND_PORT=3010
BACKEND_DATA_VOLUME=clawcontrol-backend-data
# Bind to localhost when the desktop reaches Agent Secrets through SSH tunnel.
# Bind to the VM Tailscale IP, never 0.0.0.0, when laptops connect directly.
SECRET_BROKER_BIND=127.0.0.1:4815
SECRET_BROKER_DATA_VOLUME=clawcontrol-agentsecrets-data
MEMD_SERVER_BUILD_CONTEXT=/home/aparcedodev/memd
MEMD_SERVER_DOCKERFILE=deploy/docker/Dockerfile.memd-server
MEMD_RAG_BUILD_CONTEXT=/home/aparcedodev/memd
MEMD_RAG_DOCKERFILE=/home/aparcedodev/stacks/clawcontrol-backend/docker/memd-rag-sidecar.Dockerfile
MEMD_BIND=0.0.0.0:8787
MEMD_BASE_URL=http://127.0.0.1:8787
MEMD_DATA_BIND=/home/aparcedodev/.local/share/memd
MEMD_RAG_BIND=0.0.0.0:9000
MEMD_RAG_URL=http://127.0.0.1:9000
MEMD_SERVER_RAG_URL=http://memd-rag-sidecar:9000
MEMD_RAG_DATA_VOLUME=clawcontrol-memd-rag-data
LIGHTRAG_BASE_URL=http://100.124.53.97:9621
LIGHTRAG_API_KEY=
BACKEND_PUBLIC_BASE_URL=https://coaching.aparcedo.org
CORS_ALLOWED_ORIGINS=https://coaching.aparcedo.org
PAIRING_TOKEN=replace-with-pairing-token
MC_AGENT_KEY=replace-with-stable-agent-key
SUPABASE_URL=https://your-supabase.example.com
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GITHUB_ENABLED=true
HARNESS_API_URL=http://127.0.0.1:3939
HARNESS_API_KEY=
HARNESS_WS=ws://127.0.0.1:18789/ws
HARNESS_PASSWORD=
# Legacy provider-specific aliases. Prefer HARNESS_* for new setup.
OPENCLAW_API_URL=
OPENCLAW_API_KEY=
OPENCLAW_WS=
OPENCLAW_PASSWORD=
# Desktop/private-hosted clients should use the same private URL here and in
# ClawControl Settings. Plain HTTP is accepted only on loopback/LAN/Tailscale;
# public hosts must use HTTPS.
AGENTSECRETS_URL=http://127.0.0.1:4815
AGENTSECRETS_CLIENT_API_KEY=replace-with-client-key
SECRET_BROKER_MODE=monitor
SECRET_BROKER_CLIENT_API_KEY=replace-with-client-key
SECRET_BROKER_APPROVER_API_KEY=replace-with-approver-key
SECRET_BROKER_ALLOWED_TARGET_PREFIXES=
SECRET_BROKER_MAX_AMOUNT_CENTS=10000
SECRET_BROKER_CAPABILITY_TTL_SECONDS=300
SECRET_BROKER_REQUEST_TTL_SECONDS=86400
SECRET_BROKER_RATE_LIMIT_PER_MINUTE=60
SECRET_BROKER_BITWARDEN_BASE_URL=
SECRET_BROKER_BITWARDEN_TOKEN=
SECRET_BROKER_BITWARDEN_TIMEOUT_SECONDS=30
AGENTSHELL_URL=
BLUEBUBBLES_HOST=
BLUEBUBBLES_PASSWORD=
COUCHDB_URL=
COUCHDB_USER=
COUCHDB_PASSWORD=
COUCHDB_DATABASE=clawcontrol-vault
COUCHDB_CUSTOM_HEADERS=
