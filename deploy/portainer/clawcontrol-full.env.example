STACK_BUILD_CONTEXT=/opt/clawcontrol-bundle/clawcontrol
AGENTSECRETS_BUILD_CONTEXT=/opt/clawcontrol-bundle/AgentSecrets
MEMD_BUILD_CONTEXT=/opt/clawcontrol-bundle/memd
MAC_BRIDGE_BUILD_CONTEXT=/opt/clawcontrol-bundle/mac-bridge
MEMD_RAG_DOCKERFILE=/opt/clawcontrol-bundle/clawcontrol/docker/memd-rag-sidecar.Dockerfile
MAC_BRIDGE_DOCKERFILE=/opt/clawcontrol-bundle/clawcontrol/docker/mac-bridge.Dockerfile
SUPABASE_GATEWAY_CONF=/opt/clawcontrol-bundle/clawcontrol/docker/supabase-gateway.conf
SUPABASE_MIGRATIONS_PATH=/opt/clawcontrol-bundle/clawcontrol/supabase/migrations
BACKEND_DATA_VOLUME=clawcontrol-backend-data
SECRET_BROKER_DATA_VOLUME=clawcontrol-agentsecrets-data
MEMD_DATA_VOLUME=clawcontrol-memd-data
MEMD_RAG_DATA_VOLUME=clawcontrol-memd-rag-data
LIGHTRAG_DATA_VOLUME=clawcontrol-lightrag-data
RAGANYTHING_DATA_VOLUME=clawcontrol-raganything-data
SUPABASE_DB_VOLUME=clawcontrol-supabase-db-data
SUPABASE_STORAGE_VOLUME=clawcontrol-supabase-storage-data

FRONTEND_BIND=127.0.0.1:8088
FRONTEND_PUBLIC_API_BASE=http://localhost:3010
FRONTEND_PUBLIC_SITE_URL=http://localhost:8088
FRONTEND_PUBLIC_ASSET_BASE=/
BACKEND_BIND=127.0.0.1:3010
BACKEND_BIND_PORT=3010
BACKEND_PUBLIC_BASE_URL=http://localhost:3010
CORS_ALLOWED_ORIGINS=http://localhost:8088

POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=postgres
JWT_SECRET=replace-with-at-least-32-chars
JWT_EXP=3600
SUPABASE_PUBLIC_URL=http://localhost:8000
SUPABASE_BIND=127.0.0.1:8000
SUPABASE_URL=http://supabase-gateway:8000
SUPABASE_ANON_KEY=replace-with-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-jwt
REALTIME_SECRET_KEY_BASE=replace-with-48-byte-secret
REALTIME_DB_ENC_KEY=supabaserealtime
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GITHUB_ENABLED=false
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/api/auth/callback,http://localhost:3010/api/auth/callback

PAIRING_TOKEN=replace-with-pairing-token
MC_AGENT_KEY=replace-with-stable-agent-key

SECRET_BROKER_BIND=127.0.0.1:4815
SECRET_BROKER_CLIENT_API_KEY=replace-with-client-key
SECRET_BROKER_APPROVER_API_KEY=replace-with-approver-key
SECRET_BROKER_MODE=monitor
SECRET_BROKER_ALLOWED_TARGET_PREFIXES=
SECRET_BROKER_MAX_AMOUNT_CENTS=10000
SECRET_BROKER_CAPABILITY_TTL_SECONDS=300
SECRET_BROKER_REQUEST_TTL_SECONDS=86400
SECRET_BROKER_RATE_LIMIT_PER_MINUTE=60
SECRET_BROKER_BITWARDEN_BASE_URL=
SECRET_BROKER_BITWARDEN_TOKEN=
SECRET_BROKER_BITWARDEN_TIMEOUT_SECONDS=30
AGENTSECRETS_URL=http://secret-broker:4815
AGENTSECRETS_CLIENT_API_KEY=replace-with-client-key

AGENTSHELL_BIND=127.0.0.1:8077
AGENTSHELL_URL=http://agentshell:8077
HARNESS_API_BIND=127.0.0.1:3939
HARNESS_API_URL=http://harness-api:3939
HARNESS_API_KEY=
HARNESS_WS=ws://harness-api:3939/ws
HARNESS_PASSWORD=

MEMD_BIND=127.0.0.1:8787
MEMD_BASE_URL=http://memd-server:8787
MEMD_RAG_BIND=127.0.0.1:9000
MEMD_RAG_URL=http://memd-rag-sidecar:9000
LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:latest
LIGHTRAG_BIND=127.0.0.1:9621
LIGHTRAG_BASE_URL=http://lightrag:9621
LIGHTRAG_API_KEY=
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_BINDING_HOST=https://api.openai.com/v1
LIGHTRAG_LLM_BINDING_API_KEY=
LIGHTRAG_LLM_MODEL=gpt-5-mini
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_BINDING_HOST=https://api.openai.com/v1
LIGHTRAG_EMBEDDING_BINDING_API_KEY=
LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-large
LIGHTRAG_EMBEDDING_DIM=3072
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
RAGANYTHING_BIND=127.0.0.1:8010
RAGANYTHING_URL=http://raganything-miner:8010
MINERU_URL=http://raganything-miner:8010
MINERU_MODEL_SOURCE=local

# mac-bridge ships as a profile because Apple services require a macOS host.
# Start with: docker compose --profile macos up -d mac-bridge
MAC_BRIDGE_BIND=127.0.0.1:4100
MAC_BRIDGE_HOST=
MAC_BRIDGE_API_KEY=

BLUEBUBBLES_HOST=
BLUEBUBBLES_PASSWORD=
