# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
frontend/node_modules

# testing
/coverage
frontend/coverage/

# production
/build
frontend/dist

# misc
.DS_Store
*.pem

# databases
*.db
*.sqlite
*.sqlite3

# debug / logs
*.log
npm-debug.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# IDEs
.vscode/
.idea/

# typescript
*.tsbuildinfo

# Tauri
src-tauri/target/
src-tauri/gen/
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep
src-tauri/resources/*
!src-tauri/resources/.gitkeep

# Claude Code
.claude/

# Supabase
supabase/.temp/
