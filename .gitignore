# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
frontend/node_modules

# testing
/coverage
frontend/coverage/

# production
/build
frontend/dist

# misc
.DS_Store
._*
.AppleDouble/
*.pem
# Match both the real bundle dir in the main repo and any worktree
# symlinks pointing at it. Trailing slash would only match directories,
# missing the symlink case.
.memd
.superpowers/
dogfood-output/

# databases
*.db
*.sqlite
*.sqlite3

# debug / logs
*.log
npm-debug.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# IDEs
.vscode/
.idea/

# typescript
*.tsbuildinfo

# Tauri
.cargo-target/
src-tauri/target/
src-tauri/gen/
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep
src-tauri/resources/*
!src-tauri/resources/.gitkeep

# Claude Code
.claude/
CLAUDE.md

# Playwright MCP
.playwright-mcp/

# Supabase
supabase/.temp/
.security/
