# ─────────────────────────────────────────────────────────────
# Supabase Docker Compose — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# Then fill in the values below.
#
# Generate secrets:
#   POSTGRES_PASSWORD:  openssl rand -base64 24
#   JWT_SECRET:         openssl rand -base64 32
#   ANON_KEY / SERVICE_ROLE_KEY: see README.md "Generating JWT keys"
# ─────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────

# Strong password for the PostgreSQL superuser
POSTGRES_PASSWORD=your-super-secret-postgres-password

# Secret used to sign/verify JWTs (min 32 chars)
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# JWT tokens generated from JWT_SECRET (see README.md)
ANON_KEY=your-anon-jwt-here
SERVICE_ROLE_KEY=your-service-role-jwt-here

# ── URLs ─────────────────────────────────────────────────────

# Where the frontend runs (used by GoTrue for redirects)
SITE_URL=http://localhost:5173

# External API URL (Kong or direct PostgREST)
API_EXTERNAL_URL=http://localhost:8000

# Allowed OAuth redirect URLs (comma-separated)
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/api/auth/callback

# ── Optional — Port overrides ────────────────────────────────
# Uncomment to change default ports if they conflict

# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# PGRST_PORT=3001
# AUTH_PORT=9999
# REALTIME_PORT=4000
# STORAGE_PORT=5000
# META_PORT=8080

# ── Optional — Realtime secret ───────────────────────────────
# Generate with: openssl rand -base64 48
# REALTIME_SECRET_KEY_BASE=

# ── Optional — JWT expiry (seconds, default 3600 = 1 hour) ──
# JWT_EXP=3600
