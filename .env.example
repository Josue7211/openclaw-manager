# ── Required ──────────────────────────────────────────────────
VITE_SITE_URL=http://localhost:5173
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# API authentication key (required in production, optional in dev)
MC_API_KEY=your-api-key

# Backend API URL (defaults to http://127.0.0.1:3000 if unset)
# VITE_API_BASE=http://127.0.0.1:3000

# ── Homelab (optional) ───────────────────────────────────────
# PROXMOX_HOST=https://your-proxmox-host:8006
# PROXMOX_TOKEN_ID=user@pam!token-name
# PROXMOX_TOKEN_SECRET=your-token-secret

# OPNSENSE_HOST=https://your-opnsense-host
# OPNSENSE_KEY=your-opnsense-key
# OPNSENSE_SECRET=your-opnsense-secret

# ── Notifications (optional — ntfy) ──────────────────────────
# NTFY_URL=https://ntfy.sh
# NTFY_TOPIC=your-ntfy-topic

# ── Calendar (optional — CalDAV) ─────────────────────────────
# CALDAV_URL=https://your-caldav-server.example.com
# CALDAV_USERNAME=your-caldav-username
# CALDAV_PASSWORD=your-caldav-password

# ── Mac Bridge (optional — macOS Reminders, Contacts) ────────
# MAC_BRIDGE_HOST=http://127.0.0.1:5050
# MAC_BRIDGE_API_KEY=your-mac-bridge-api-key

# ── BlueBubbles iMessage (optional — requires Mac with BlueBubbles Server)
# BLUEBUBBLES_HOST=http://your-bluebubbles-host:1234
# BLUEBUBBLES_PASSWORD=your-bluebubbles-password

# ── Email IMAP (optional) ────────────────────────────────────
# EMAIL_HOST=imap.your-email-provider.com
# EMAIL_PORT=993
# EMAIL_USER=your-email@example.com
# EMAIL_PASSWORD=your-email-password
# EMAIL_TLS=true

# ── Media (optional — Plex, Sonarr, Radarr) ─────────────────
# PLEX_URL=http://your-plex-host:32400
# PLEX_TOKEN=your-plex-token
# SONARR_URL=http://your-sonarr-host:8989
# SONARR_API_KEY=your-sonarr-api-key
# RADARR_URL=http://your-radarr-host:7878
# RADARR_API_KEY=your-radarr-api-key

# ── OpenClaw AI workspace (optional) ─────────────────────────
# OPENCLAW_WS=ws://your-openclaw-host:18789
# OPENCLAW_PASSWORD=your-openclaw-password
# OPENCLAW_API_URL=http://your-openclaw-host:8080
# OPENCLAW_API_KEY=your-openclaw-api-key

# ── AgentShell adapter (optional) ───────────────────────────
# AGENTSHELL_URL=http://your-agentshell-host:8077

# OpenClaw frontend display (optional — shown in Settings page)
# VITE_OPENCLAW_WS=ws://your-openclaw-host:18789
# VITE_OPENCLAW_HTTP=http://your-openclaw-host:18789

# ── iOS Quick Capture (optional) ─────────────────────────────
# CAPTURE_API_KEY=your-capture-api-key
