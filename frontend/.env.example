# Mission Control — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# All variables are prefixed with VITE_ so Vite exposes them to the browser.

# ── Tauri backend API ─────────────────────────────────────────
# Base URL for the embedded Axum server. Defaults to http://127.0.0.1:3000.
# VITE_API_BASE=http://127.0.0.1:3000

# ── OpenClaw AI workspace (optional) ──────────────────────────
# Displayed on the Settings page for connection status.
# VITE_OPENCLAW_WS=ws://your-openclaw-host:18789
# VITE_OPENCLAW_HTTP=http://your-openclaw-host:18789

# ── Vault / Notes CouchDB sync (optional) ────────────────────
# CouchDB sync is proxied through the Axum backend — no frontend
# credentials needed. Configure CouchDB connection in Settings or
# via the OS keychain (see src-tauri/src/secrets.rs).
