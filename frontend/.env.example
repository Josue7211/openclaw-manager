# Mission Control — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# All variables are prefixed with VITE_ so Vite exposes them to the browser.

# ── Tauri backend API ─────────────────────────────────────────
# Base URL for the embedded Axum server. Defaults to http://127.0.0.1:5000.
# VITE_API_BASE=http://127.0.0.1:5000

# ── Public web deployment ────────────────────────────────────
# Used when building the coaching web form.
# VITE_API_BASE=https://coaching.aparcedo.org
# VITE_SITE_URL=https://coaching.aparcedo.org
# VITE_ASSET_BASE=/

# ── Generic AI harness (optional) ─────────────────────────────
# Displayed on the Settings page for connection status.
# VITE_HARNESS_WS=ws://your-harness-host:18789
# VITE_HARNESS_HTTP=http://your-harness-host:18789

# ── Vault / Notes CouchDB sync (optional) ────────────────────
# CouchDB sync is proxied through the Axum backend — no frontend
# credentials needed. Configure CouchDB connection in Settings or
# via the OS keychain (see src-tauri/src/secrets.rs).
