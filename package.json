{
  "name": "clawctrl-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:test": "npm --prefix frontend run test",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:dead-code": "node scripts/check-dead-code.mjs",
    "check:tauri": "cargo check --manifest-path src-tauri/Cargo.toml --bin clawctrl",
    "portainer:certify-live": "node scripts/portainer-live-certify.mjs",
    "portainer:test-certify-readonly": "node scripts/test-portainer-live-certify-readonly.mjs",
    "portainer:test-certify-disposable": "node scripts/test-portainer-live-certify-disposable.mjs",
    "proxmox:certify-live": "node scripts/proxmox-live-certify.mjs",
    "proxmox:test-certify-readonly": "node scripts/test-proxmox-live-certify-readonly.mjs",
    "proxmox:test-certify-write": "node scripts/test-proxmox-live-certify-write.mjs",
    "check": "npm run check:architecture && npm --prefix frontend run typecheck && npm run check:bundle && npm run check:dead-code",
    "check:all": "npm run check && npm --prefix frontend run test && npm run check:tauri"
  }
}
