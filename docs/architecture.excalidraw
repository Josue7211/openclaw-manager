    {
      "type": "text",
      "id": "proxy_routes",
      "x": 75, "y": 256,
      "width": 360, "height": 150,
      "text": "Axum proxies ALL external calls:\n\n  /api/chat/*       \u2192 OpenClaw (AI gateway)\n  /api/messages/*   \u2192 BlueBubbles (iMessage)\n  /api/vault/*      \u2192 CouchDB (Obsidian notes)\n  /api/reminders    \u2192 Mac Bridge (Apple services)\n  /api/homelab      \u2192 Proxmox / OPNsense\n  /api/calendar     \u2192 CalDAV (iCloud, etc.)\n  /api/auth/*       \u2192 Supabase Auth\n  /api/events       \u2192 Supabase Realtime",
      "originalText": "Axum proxies ALL external calls:\n\n  /api/chat/*       \u2192 OpenClaw (AI gateway)\n  /api/messages/*   \u2192 BlueBubbles (iMessage)\n  /api/vault/*      \u2192 CouchDB (Obsidian notes)\n  /api/reminders    \u2192 Mac Bridge (Apple services)\n  /api/homelab      \u2192 Proxmox / OPNsense\n  /api/calendar     \u2192 CalDAV (iCloud, etc.)\n  /api/auth/*       \u2192 Supabase Auth\n  /api/events       \u2192 Supabase Realtime",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#94a3b8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
